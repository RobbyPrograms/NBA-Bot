# Copy to .env.local and fill in (never commit .env.local).
# Supabase → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Optional: server-only; use if RLS blocks anon reads on slate_reports
# SUPABASE_SERVICE_ROLE_KEY=

# Railway MUST set both for automatic slate_reports uploads after each successful run:
#   SUPABASE_URL=https://xxxx.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...   (service_role, not anon — RLS blocks anon insert)

# --- Railway (railway_server.py) — not used by Next.js locally unless you mirror these
# How often to re-run the full predictor (seconds). Default in code is 6 hours.
# ROLI_REFRESH_SECONDS=1800
# Delay before first run after boot (seconds).
# ROLI_FIRST_RUN_DELAY_SECONDS=0
# POST /refresh auth (optional manual refresh while testing)
# ROLI_REFRESH_SECRET=your_secret
